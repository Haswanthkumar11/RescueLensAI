# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` (it is already in .gitignore) and never put real
# secrets in this .example file — it IS meant to be committed to git.

# --- AI ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Google deprecates/shuts down Gemini model IDs on a rolling basis
# (see https://ai.google.dev/gemini-api/docs/changelog). If analysis
# starts failing with "model is no longer available", update this one
# value instead of touching code.
GEMINI_MODEL=gemini-3.5-flash

# --- Supabase ---
# Project Settings -> API in your Supabase dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
# This is the SERVICE ROLE key (secret, full-access). Never expose it to
# the frontend or a browser — it is used server-side only.
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here
SUPABASE_BUCKET=incident-images

# --- App ---
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:5173
